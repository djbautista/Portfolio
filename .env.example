# Local-dev environment manifest.
# Copy to .env and fill in the blanks (OPENAI_API_KEY).
# In production, ECS task defs / Secrets Manager / SSM inject these same
# names; no .env file is deployed.

# Postgres credentials consumed by docker-compose (with these defaults
# baked into docker-compose.yml as fallbacks).
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio
POSTGRES_DB=portfolio_ai
POSTGRES_PORT=5432

# Postgres connection string consumed by Node code (Prisma, scripts).
# NOTE: Node's --env-file and dotenv do NOT expand ${VAR}, so this must
# be a literal URL. If you change any POSTGRES_* above, update this line
# to match (or just leave both at their defaults).
DATABASE_URL=postgresql://portfolio:portfolio@localhost:5432/portfolio_ai?schema=public

# OpenAI embeddings (consumed by @portfolio/db and future packages).
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Chat completions (consumed by @portfolio/agent).
CHAT_MODEL=gpt-4o-mini
CHAT_TIMEOUT_MS=30000
CHAT_MAX_TOKENS=1024

# HTTP API (consumed by @portfolio/api).
API_HOST=127.0.0.1
API_PORT=3001
# Comma-separated allowlist of CORS origins. Leave unset in development to
# allow all origins; in production, an unset value denies cross-origin
# requests by default.
API_CORS_ORIGINS=

# Optional. Public WhatsApp number used by the chat widget's "Continue on
# WhatsApp" affordance and the /whatsapp slash command. This is the human-
# facing number for the `wa.me` deep link — include the country code with a
# leading '+' (e.g. +14155550123); the link builder strips non-digits.
# Leave empty (or unset) to gracefully hide all WhatsApp UI — the chat
# header icon, the persistent WhatsApp line, and the /whatsapp slash
# command are all removed when no number is configured.
# This MUST be the same human number behind TWILIO_WHATSAPP_NUMBER below.
NEXT_PUBLIC_PORTFOLIO_WHATSAPP_NUMBER=

# Twilio WhatsApp integration (consumed by @portfolio/api).
# All four vars are required for the inbound webhook + outbound reply to do
# real work. Missing any one makes /webhooks/twilio/whatsapp return 503.
# Never expose TWILIO_AUTH_TOKEN to the frontend.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Backend sender value used by the Twilio REST API. Must be exactly
# `whatsapp:+<E164>` (e.g. whatsapp:+14155550123). Different format from
# NEXT_PUBLIC_PORTFOLIO_WHATSAPP_NUMBER above on purpose.
TWILIO_WHATSAPP_NUMBER=
# Exact public URL the Twilio Console is configured to call. Used as the
# `url` argument to Twilio's signature validator — must match scheme, host,
# path, and not end with a trailing slash. Example:
# https://api.davidbautista.co/webhooks/twilio/whatsapp
TWILIO_WEBHOOK_PUBLIC_URL=
