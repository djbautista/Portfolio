{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "//": "globalEnv lists cross-cutting vars that can affect any task's output. Coarse-grained for this 3-package repo; refine via per-task `env` once tasks diverge meaningfully in what they read.",
  "globalEnv": [
    "DATABASE_URL",
    "OPENAI_API_KEY",
    "EMBEDDING_MODEL",
    "EMBEDDING_DIMENSIONS",
    "CHAT_MODEL",
    "CHAT_TIMEOUT_MS",
    "CHAT_MAX_TOKENS",
    "NODE_ENV",
    "AGENT_API_URL",
    "NEXT_PUBLIC_PORTFOLIO_WHATSAPP_NUMBER"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
