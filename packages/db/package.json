  "dependencies": {
    "@portfolio/content": "workspace:*",
    "@portfolio/contracts": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "openai": "^5.0.0",
    "pgvector": "^0.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@portfolio/eslint-config": "workspace:*",
    "@portfolio/typescript-config": "workspace:*",
    "eslint": "^9.39.1",
    "prisma": "^7.8.0",
    "tsx": "^4.22.3",
    "typescript": "5.9.2"
  }
