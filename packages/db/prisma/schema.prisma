// Portfolio AI assistant — MVP data model.
//
// Pipeline shape supported by this schema:
//   Web/channel input -> API -> Agentic RAG -> Postgres/pgvector retrieval
//   -> answer -> trace persistence.
//
// pgvector note:
// The initial migration creates the `vector` extension via raw SQL
// (`CREATE EXTENSION IF NOT EXISTS vector;`) and defines an HNSW index on
// `DocumentChunk.embedding`. The docker-compose bootstrap in
// `infra/postgres/init.sql` also enables the extension, but the migration
// no longer depends on that — any Postgres environment can apply the
// migrations directly.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// Conversation + Message
// -----------------------------------------------------------------------------

model Conversation {
  id        String   @id @default(cuid())
  userId    String?
  channel   String
  title     String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages      Message[]
  agentTraces   AgentTrace[]
  channelEvents ChannelEvent[]

  @@index([userId])
  @@index([channel])
  @@index([createdAt])
}

model Message {
  id                String   @id @default(cuid())
  conversationId    String
  role              String
  content           String
  // Inbound provider message id (e.g. an external message identifier from
  // whichever channel/provider delivered the message). Not globally unique:
  // ids minted by different providers can collide, and real idempotency must
  // be scoped per provider — add `Message.provider` + a composite unique
  // constraint when message-level dedup is implemented.
  providerMessageId String?
  metadata          Json?
  createdAt         DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([role])
  @@index([providerMessageId])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// Document + DocumentChunk (knowledge base, pgvector-backed)
// -----------------------------------------------------------------------------

model Document {
  id          String   @id @default(cuid())
  title       String
  sourceType  String
  sourceUri   String?
  contentHash String?
  isActive    Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chunks DocumentChunk[]

  @@index([sourceType])
  @@index([isActive])
  @@index([contentHash])
}

model DocumentChunk {
  id         String                       @id @default(cuid())
  documentId String
  chunkIndex Int
  title      String?
  content    String
  // 1536 dims targets OpenAI text-embedding-3-small / ada-002. Adjust here
  // (and re-migrate) if a different embedding model is adopted.
  embedding  Unsupported("vector(1536)")?
  tokenCount Int?
  metadata   Json?
  createdAt  DateTime                     @default(now())

  document          Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  retrievedContexts RetrievedContext[]

  @@unique([documentId, chunkIndex])
  @@index([documentId])
}

// -----------------------------------------------------------------------------
// Agent traces (one per assistant turn)
// -----------------------------------------------------------------------------

model AgentTrace {
  id                    String   @id @default(cuid())
  conversationId        String?
  // MVP: kept as plain string columns — no FK to Message — so trace writes
  // don't depend on the order/success of message persistence.
  userMessageId         String?
  assistantMessageId    String?
  input                 String
  output                String?
  confidence            String?
  shouldEscalate        Boolean  @default(false)
  retrievedContextCount Int      @default(0)
  latencyMs             Int?
  model                 String?
  metadata              Json?
  createdAt             DateTime @default(now())

  conversation      Conversation?      @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  steps             AgentStep[]
  retrievedContexts RetrievedContext[]

  @@index([conversationId])
  @@index([confidence])
  @@index([createdAt])
}

model AgentStep {
  id        String   @id @default(cuid())
  traceId   String
  // Expected stepName values:
  //   intent_classifier | retrieve_context | answer_generator
  //   confidence_gate   | fallback_escalation
  stepName  String
  // Expected status values:
  //   started | completed | failed | skipped
  status    String
  input     String?
  output    String?
  latencyMs Int?
  metadata  Json?
  createdAt DateTime @default(now())

  trace AgentTrace @relation(fields: [traceId], references: [id], onDelete: Cascade)

  @@index([traceId])
  @@index([stepName])
  @@index([status])
}

model RetrievedContext {
  id              String  @id @default(cuid())
  traceId         String
  documentChunkId String?
  documentId      String?
  title           String?
  // Snapshot copy of the chunk content at retrieval time — source chunks may
  // be re-embedded, edited, or deleted later, but traces must remain faithful.
  content         String
  score           Float?
  rank            Int?
  createdAt       DateTime @default(now())

  trace         AgentTrace     @relation(fields: [traceId], references: [id], onDelete: Cascade)
  documentChunk DocumentChunk? @relation(fields: [documentChunkId], references: [id], onDelete: SetNull)

  @@index([traceId])
  @@index([documentChunkId])
  @@index([rank])
}

// -----------------------------------------------------------------------------
// Channel webhook events (inbound + outbound status callbacks, any provider)
// -----------------------------------------------------------------------------

model ChannelEvent {
  id                String   @id @default(cuid())
  conversationId    String?
  provider          String
  providerEventId   String?
  providerMessageId String?
  channel           String
  // Expected direction values:
  //   inbound | outbound
  direction         String
  // Expected eventType values:
  //   message_received | message_sent | delivery_status | error
  eventType         String
  status            String?
  from              String?
  to                String?
  body              String?
  errorCode         String?
  errorMessage      String?
  rawPayload        Json?
  metadata          Json?
  createdAt         DateTime @default(now())

  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([provider])
  @@index([channel])
  @@index([providerMessageId])
  @@index([providerEventId])
  @@index([provider, providerEventId])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// Deferred models — intentionally NOT added in this MVP slice:
//   - DocumentSource           (knowledge-source registry)
//   - KnowledgeIngestionJob    (ingestion pipeline runs)
//   - EvaluationRun            (eval suite runs)
//   - EvaluationResult         (per-case eval outcomes)
//
// These will land once ingestion reliability and evaluation workflows are
// designed. Adding them before the ingestion/eval surfaces exist would lock
// in shapes we can't yet justify.
// -----------------------------------------------------------------------------
